# =========================================================================
# CONFIGURATION LOCALE DE L'APPLICATION EURL TCP
# Renommez ce fichier en ".env" et remplissez-le avec vos identifiants réels.
# =========================================================================

# Clé API Gemini (obtenue sur Google AI Studio)
GEMINI_API_KEY="VOTRE_CLE_API_GEMINI"

# URL de l'application (http://localhost:3000 en développement)
APP_URL="http://localhost:3000"

# Chaîne de connexion PostgreSQL (ex: Neon DB)
# Format : postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=""

# Mot de passe administrateur pour déverrouiller la console de gestion du catalogue
ADMIN_PASSCODE="VOTRE_MOT_DE_PASSE_ADMIN_ROBUSTE_ET_SECRET"
